rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════════
// FIREBASE STORAGE RULES — GraphR App
// ═══════════════════════════════════════════════════════════════════════════════
// Deploy: firebase deploy --only storage
//
// Handles storage of:
//   • Student profile pictures
//   • Exam attachments
//   • Instructional materials
//

service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile Pictures ───────────────────────────────────────────────────
    // Users can upload their own profile picture
    // Anyone can read (for classroom listings)
    match /profiles/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 && // 5 MB max
        request.resource.contentType.matches('image/.*');
    }

    // ── Exam Attachments ───────────────────────────────────────────────────
    // Teachers can upload exam materials
    // Students can read exams for their classrooms
    match /exams/{examId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }

    // ── Classroom Materials ────────────────────────────────────────────────
    // Teachers can manage classroom materials
    // Students can read their classroom materials
    match /classrooms/{classroomId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }

    // ── Default: Deny All ──────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
