{
  "expo": {
    "name": "GraphR",
    "slug": "graphr-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1a1a1a",
    "scheme": "com.graphrapp.graphr",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1419"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.graphrapp.graphr",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GraphR uses location for classroom-based features.",
        "NSCameraUsageDescription": "Take a photo for your profile.",
        "NSPhotoLibraryUsageDescription": "Choose a photo for your profile.",
        "NSBluetoothPeripheralUsageDescription": "GraphR may use Bluetooth for exam proctoring.",
        "SKPaymentQueueTransactionObserverSupportedPaymentNetworks": [
          "Visa",
          "MasterCard",
          "AmericanExpress",
          "Discover"
        ]
      },
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.com.graphrapp.graphr"
        ],
        "aps-environment": "production"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.graphrapp.graphr",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "com.android.vending.BILLING",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a73e8"
        }
      ],
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR-EAS-PROJECT-ID-HERE"
      }
    },
    "owner": "YOUR-EXPO-USERNAME"
  }
}
